{
  "name": "@sikao/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 18080 --strictPort",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 18080 --strictPort",
    "typecheck": "tsc -b --noEmit",
    "lint": "npm run lint:eslint && npm run lint:guardrails",
    "lint:eslint": "eslint .",
    "lint:guardrails": "npm run lint:icon-button && npm run lint:no-emoji-as-icon && npm run lint:italic && npm run lint:cn-simplified",
    "lint:guardrails:full": "npm run lint:guardrails && npm run lint:practice-svg-only",
    "lint:hardcode": "node ./scripts/lint-hardcode.mjs",
    "lint:radius-token": "node ./scripts/lint-radius-token.mjs",
    "lint:ui-copy-ssot": "node ./scripts/lint-ui-copy-ssot.mjs",
    "lint:icon-button": "node ./scripts/lint-icon-button.mjs",
    "lint:no-emoji-as-icon": "node ./scripts/lint-no-emoji-as-icon.mjs",
    "lint:practice-svg-only": "node ./scripts/lint-practice-svg-only.mjs",
    "lint:italic": "node ./scripts/lint-italic.mjs",
    "lint:cn-simplified": "node ./scripts/lint-cn-simplified.mjs",
    "lint:breadcrumb-comments": "node ./scripts/lint-breadcrumb-comments.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@sikao/api-client": "*",
    "@sikao/answer-engine": "*",
    "@sikao/config": "*",
    "@sikao/design-system": "*",
    "@sikao/domain": "*",
    "@sikao/editor": "*",
    "@sikao/shared-utils": "*",
    "@sikao/ui": "*",
    "@tanstack/react-query": "^5.99.2",
    "axios": "^1.15.1",
    "dompurify": "^3.4.1",
    "framer-motion": "^11.18.2",
    "lodash-es": "^4.18.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.0",
    "msw": "^2.13.6",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  }
}
