{
  "name": "sikao",
  "private": true,
  "version": "0.0.0",
  "description": "SIKAO — 公考备考工具单仓（apps/packages/services 分层）",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @sikao/web",
    "build": "npm run build -w @sikao/web",
    "generate:types": "bash scripts/generate-api-types.sh",
    "bootstrap:mvp-demo": "bash scripts/dev-python.sh -m scripts.import.import_mvp_demo",
    "seed:mvp-demo": "bash scripts/dev-python.sh -m scripts.import.import_mvp_demo --skip-migrations",
    "gate:preflight": "node scripts/gates/gate-runner.mjs preflight",
    "gate:validation": "node scripts/gates/gate-runner.mjs validation --profile full",
    "lint": "npm run lint --workspaces --if-present",
    "test:gates": "node --test scripts/gates/*.test.mjs",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
