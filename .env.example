# sikao backend env — template
#
# 用法：复制本文件到 services/api/.env（gitignored），按本机环境填值。
# pydantic BaseSettings 从 services/api/.env 读取（详见 services/api/src/sikao_api/core/config.py:116）。
#
# 另：sikao 还有 <repo_root>/.env/ **目录**（gitignored），用于存 secret 凭据文件：
#   - .env/apikey                — LLM apikey（DeepSeek 等，详见 config.py:340-348）
#   - 其他敏感凭据按需放此目录
# multica token **不**放本仓库 —— 走 `multica login` 命令管理（CLAUDE.md §13 安全）。

# ─── App ──────────────────────────────────────────────────────────────
APP_ENV=local                                # local / test / poc / prod
APP_PORT=8000
APP_BASE_URL=http://127.0.0.1:8000
LOG_LEVEL=info                               # debug / info / warning / error

# ─── Database ─────────────────────────────────────────────────────────
# 本地 native PG（CLAUDE.md §11 全场景禁 docker）。
# 期望端口 5432（CLAUDE.md §11.5 SSOT）。
DATABASE_URL=postgresql+psycopg://exam_api:secret@127.0.0.1:5432/exam_api
DB_POOL_SIZE=5
DB_POOL_MAX_OVERFLOW=10
DB_ECHO=false

# ─── 题库冷存（CLAUDE.md §12） ─────────────────────────────────────────
# 仓库外目录（行测 fenbi mirror + 申论 standard json）。
BACKEND_DATA_ROOT=D:/py_pj/backend_data

# ─── JWT ──────────────────────────────────────────────────────────────
# prod 必须 secrets.token_hex(32) 真值，不能用 'change-me'（config.py:424 fail-fast）。
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXP_MINUTES=120
AUTH_COOKIE_SECURE=false                     # prod 必须 true（https only）

# ─── Admin ────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
# ADMIN_PASSWORD_HASH 走默认 argon2(adminpass)，prod 必须改。

# ─── CORS（前端 18080 唯一） ──────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://127.0.0.1:18080,http://localhost:18080,http://127.0.0.1:8000,http://localhost:8000

# ─── Frontend base URL ────────────────────────────────────────────────
FRONTEND_BASE_URL=http://127.0.0.1:18080

# ─── Email / SMS providers ───────────────────────────────────────────
EMAIL_PROVIDER=stub                          # stub (dev logger) / noop / resend
SMS_PROVIDER=stub                            # stub / noop / tencent
DEV_EXPOSE_MAGIC_LINK=false                  # poc/prod 必须 false（leak risk）
DEV_EXPOSE_MAGIC_CODE=false                  # 同上

# Resend (email_provider=resend 时必填)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# RESEND_REPLY_TO=

# 腾讯云 SMS (sms_provider=tencent 时必填)
# TENCENT_SMS_SECRET_ID=
# TENCENT_SMS_SECRET_KEY=
# TENCENT_SMS_APP_ID=
# TENCENT_SMS_SIGN_NAME=
# TENCENT_SMS_TEMPLATE_REGISTER=
# TENCENT_SMS_TEMPLATE_BIND=

# ─── LLM infra ────────────────────────────────────────────────────────
# apikey 走 <repo_root>/.env/apikey 文件 fallback（不放 LLM_API_KEY=...）。
LLM_PROVIDER=deepseek                        # deepseek / openai / custom
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL_QA=deepseek-v4-flash
LLM_MODEL_ESSAY=deepseek-v4-pro
LLM_MODEL_STUDY_PLAN=deepseek-v4-flash
LLM_TIMEOUT_SECONDS=120

# Slice 0c BYOM (用户 api_key AES 加密)
# 生成: python -c "import secrets; print(secrets.token_hex(32))"
# LLM_CONFIG_ENC_KEY=

# ─── Rate limiting (prod 必须 Redis) ─────────────────────────────────
# REDIS_URL=redis://localhost:6379/0
